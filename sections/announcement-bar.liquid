<div class="announcement-bar">
  <!-- Top band : countdown sur fond gradient animé -->
  <div class="announcement-bar__top">
    <p class="announcement-bar__text">
      {{ section.settings.text }}
      {%- if section.settings.show_countdown -%}
        <span class="countdown" data-hours="{{ section.settings.countdown_hours }}">
          <span class="countdown__segment">
            <span class="countdown__value" data-hours>00</span>
            <span class="countdown__unit">HRS</span>
          </span>
          <span class="countdown__sep">:</span>
          <span class="countdown__segment">
            <span class="countdown__value" data-minutes>00</span>
            <span class="countdown__unit">MIN</span>
          </span>
          <span class="countdown__sep">:</span>
          <span class="countdown__segment">
            <span class="countdown__value" data-seconds>00</span>
            <span class="countdown__unit">SEC</span>
          </span>
        </span>
      {%- endif -%}
    </p>
  </div>

  <!-- Bande marquee scrollante en dessous -->
  <div class="announcement-bar__marquee" data-marquee>
    <div class="announcement-bar__marquee-track" data-marquee-track>
      <div class="announcement-bar__marquee-group" data-marquee-group>
        {%- for block in section.blocks -%}
          <span class="announcement-bar__marquee-item" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Countdown label",
      "default": "SALE ENDS IN"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown timer",
      "default": true
    },
    {
      "type": "number",
      "id": "countdown_hours",
      "label": "Countdown duration (hours)",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "GOLD RESTOCK! 54% OFF + FREE SHIPPING TODAY ONLY"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "item", "settings": { "text": "GOLD RESTOCK!" } },
        { "type": "item", "settings": { "text": "54% OFF + FREE SHIPPING TODAY ONLY" } },
        { "type": "item", "settings": { "text": "GOLD RESTOCK!" } },
        { "type": "item", "settings": { "text": "54% OFF + FREE SHIPPING TODAY ONLY" } }
      ]
    }
  ]
}
{% endschema %}
