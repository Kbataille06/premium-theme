<footer class="footer">
  <div class="footer__inner container">

    <div class="footer__top">
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 140 | image_tag: width: 140, alt: shop.name }}
        {%- else -%}
          <span class="footer__shop-name">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      <div class="footer__links">
        <p class="footer__nav-heading">Assistance</p>
        <nav aria-label="Footer navigation">
          <ul class="footer__nav-list">
            {%- for link in linklists[section.settings.menu].links -%}
              <li><a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>

      <div class="footer__social-block">
        <p class="footer__social-heading">Suivez-nous</p>
        <div class="footer__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>

      {%- if section.settings.show_country_selector -%}
        <div class="footer__localization">
          {% form 'localization', class: 'localization-form' %}
            <select name="country_code" class="localization-form__select" onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                  {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </option>
              {%- endfor -%}
            </select>
          {% endform %}
        </div>
      {%- endif -%}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Authentic patented chrome earbuds, sold exclusively by us."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/region selector",
      "default": true
    }
  ]
}
{% endschema %}
