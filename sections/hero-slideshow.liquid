<section class="slideshow" data-slideshow data-autoplay="{{ section.settings.autoplay }}" data-interval="{{ section.settings.interval }}">
  <div class="slideshow__track" data-slideshow-track>
    {%- for block in section.blocks -%}
      <div class="slideshow__slide{% if forloop.first %} is-active{% endif %}" data-slide {{ block.shopify_attributes }}>
        <div class="slideshow__media">
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: muted: true, loop: true, autoplay: true, controls: false, playsinline: true, class: 'slideshow__video' }}
          {%- elsif block.settings.video_url != blank -%}
            <video class="slideshow__video" src="{{ block.settings.video_url }}" muted loop autoplay playsinline></video>
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 2200 | image_tag: loading: forloop.first | ternary: 'eager','lazy', class: 'slideshow__img', alt: block.settings.heading }}
          {%- else -%}
            <div class="slideshow__img slideshow__img--ph">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {%- endif -%}
          <div class="slideshow__overlay" style="opacity: {{ block.settings.overlay | divided_by: 100.0 }};"></div>
        </div>
        <div class="slideshow__content slideshow__content--{{ block.settings.align }}">
          {%- if block.settings.eyebrow != blank -%}<p class="slideshow__eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h2 class="slideshow__heading">{{ block.settings.heading }}</h2>{%- endif -%}
          {%- if block.settings.subheading != blank -%}<p class="slideshow__subheading">{{ block.settings.subheading }}</p>{%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_url }}" class="btn btn--primary btn--lg slideshow__btn">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="slideshow__arrow slideshow__arrow--prev" data-slide-prev aria-label="Précédent">‹</button>
    <button class="slideshow__arrow slideshow__arrow--next" data-slide-next aria-label="Suivant">›</button>
    <div class="slideshow__dots" data-slide-dots></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero slideshow",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Défilement auto", "default": true },
    { "type": "range", "id": "interval", "label": "Intervalle (s)", "min": 3, "max": 10, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image de fond" },
        { "type": "video", "id": "video", "label": "Vidéo de fond (upload)" },
        { "type": "url", "id": "video_url", "label": "Ou URL vidéo (.mp4)" },
        { "type": "range", "id": "overlay", "label": "Assombrissement", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 35 },
        { "type": "select", "id": "align", "label": "Position du texte", "options": [ { "value": "left", "label": "Gauche" }, { "value": "center", "label": "Centre" }, { "value": "right", "label": "Droite" } ], "default": "center" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Titre", "default": "Votre titre ici" },
        { "type": "textarea", "id": "subheading", "label": "Sous-titre" },
        { "type": "text", "id": "button_label", "label": "Texte bouton", "default": "DÉCOUVRIR" },
        { "type": "url", "id": "button_url", "label": "Lien bouton" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [ { "type": "slide" }, { "type": "slide" } ]
    }
  ]
}
{% endschema %}
