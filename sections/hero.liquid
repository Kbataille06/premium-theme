<section class="hero" style="background-color: {{ section.settings.bg_color }};">
  <div class="hero__inner container">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="hero__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="hero__heading-accent">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="hero__cta-group">
          <a href="{{ section.settings.button_url }}" class="btn btn--primary btn--lg">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}

      {%- if section.settings.show_trust_strip -%}
        <div class="hero__trust">
          <span class="hero__trust-item">✓ Satisfait ou remboursé 30 jours</span>
          <span class="hero__trust-item">✓ Livraison gratuite</span>
          <span class="hero__trust-item">✓ 150 000+ clients satisfaits</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (before accent)",
      "default": "Built to move"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent word (gradient blanc → gris)",
      "default": "Different."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Striking design. Powerful sound. Zero compromise."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show trust strip",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#fffefd"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
