<section class="iconrow section-padding-sm" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="iconrow__items iconrow__items--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div class="iconrow__item" {{ block.shopify_attributes }}>
          <div class="iconrow__icon">
            {%- case block.settings.icon -%}
              {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z"/></svg>
              {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M3 4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h1a3 3 0 0 0 6 0h4a3 3 0 0 0 6 0h1a1 1 0 0 0 1-1v-4l-3-4h-3V5a1 1 0 0 0-1-1H3m13 5h2.5l1.5 2h-4V9M7 14.5A1.5 1.5 0 0 1 8.5 16 1.5 1.5 0 0 1 7 17.5 1.5 1.5 0 0 1 5.5 16 1.5 1.5 0 0 1 7 14.5m10 0A1.5 1.5 0 0 1 18.5 16 1.5 1.5 0 0 1 17 17.5 1.5 1.5 0 0 1 15.5 16 1.5 1.5 0 0 1 17 14.5Z"/></svg>
              {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              {%- when 'leaf' -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"/></svg>
              {%- when 'lock' -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M12 17a2 2 0 0 0 2-2 2 2 0 0 0-2-2 2 2 0 0 0-2 2 2 2 0 0 0 2 2m6-9a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2h1V6a5 5 0 0 1 5-5 5 5 0 0 1 5 5v2h1M12 3a3 3 0 0 0-3 3v2h6V6a3 3 0 0 0-3-3Z"/></svg>
              {%- else -%}<svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            {%- endcase -%}
          </div>
          <div class="iconrow__text">
            <strong class="iconrow__title">{{ block.settings.title }}</strong>
            {%- if block.settings.text != blank -%}<span class="iconrow__sub">{{ block.settings.text }}</span>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Barre d'arguments",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#15181c" }
  ],
  "blocks": [
    {
      "type": "arg",
      "name": "Argument",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [ { "value": "lock", "label": "Cadenas" }, { "value": "truck", "label": "Camion" }, { "value": "heart", "label": "Cœur" }, { "value": "leaf", "label": "Feuille" }, { "value": "shield", "label": "Bouclier" }, { "value": "check", "label": "Check" } ], "default": "lock" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Paiements sécurisés" },
        { "type": "text", "id": "text", "label": "Sous-texte" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre d'arguments",
      "blocks": [
        { "type": "arg", "settings": { "icon": "lock", "title": "Paiements sécurisés" } },
        { "type": "arg", "settings": { "icon": "truck", "title": "Livraison rapide" } },
        { "type": "arg", "settings": { "icon": "heart", "title": "Fabriqué avec soin" } },
        { "type": "arg", "settings": { "icon": "shield", "title": "Service de confiance" } }
      ]
    }
  ]
}
{% endschema %}
