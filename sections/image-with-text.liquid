<section class="iwt section-padding-sm">
  <div class="container">
    <div class="iwt__card iwt__card--{{ section.settings.layout }}">
      <div class="iwt__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'iwt__img', alt: section.settings.heading }}
        {%- else -%}
          <div class="iwt__img iwt__img--placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      <div class="iwt__content">
        <h2 class="iwt__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p class="iwt__text">{{ section.settings.text }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn--white iwt__btn">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "text-right", "label": "Image left, text right" },
        { "value": "text-left", "label": "Image right, text left" }
      ],
      "default": "text-right"
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Unmistakable Chrome. Everyday Sound." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Built to stand out and perform. These chrome earbuds deliver crisp, immersive audio in a design that elevates every fit. Plug in, lock in, and move different." },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [
    {
      "name": "Image with text",
      "settings": {
        "layout": "text-right",
        "heading": "Unmistakable Chrome. Everyday Sound.",
        "text": "Built to stand out and perform. These chrome earbuds deliver crisp, immersive audio in a design that elevates every fit. Plug in, lock in, and move different."
      }
    }
  ]
}
{% endschema %}
