<section class="lifestyle-grid section-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="lifestyle-grid__header">
      <h2 class="lifestyle-grid__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="lifestyle-grid__accent" style="color: {{ section.settings.accent_color }};">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lifestyle-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="lifestyle-grid__items">
      {%- for block in section.blocks -%}
        <article class="lifestyle-grid__item" {{ block.shopify_attributes }}>
          <div class="lifestyle-grid__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'lifestyle-grid__image', alt: block.settings.title }}
            {%- else -%}
              <div class="lifestyle-grid__image lifestyle-grid__image--ph">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            {%- endif -%}
          </div>
          <div class="lifestyle-grid__content">
            {%- if block.settings.title != blank -%}
              <h3 class="lifestyle-grid__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="lifestyle-grid__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lifestyle grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Portez Chroma" },
    { "type": "text", "id": "heading_accent", "label": "Accent", "default": "à Votre Façon" },
    { "type": "color", "id": "accent_color", "label": "Couleur de l'accent", "default": "#FF6B35" },
    { "type": "text", "id": "subheading", "label": "Sous-titre", "default": "Tant de façons de porter vos Chromabuds" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#f6f6f8" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carte",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Titre", "default": "L'Essentiel du Quotidien" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Vos écouteurs à tout faire. Légers, fiables, conçus pour être portés toute la journée." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lifestyle grid",
      "blocks": [
        { "type": "card", "settings": { "title": "L'Essentiel du Quotidien", "description": "Vos écouteurs à tout faire. Légers, fiables, conçus pour être portés toute la journée." } },
        { "type": "card", "settings": { "title": "Conçus pour l'Extérieur", "description": "Du snowboard aux trajets en ville, ils tiennent le coup. Pas d'encombrement, juste à brancher." } },
        { "type": "card", "settings": { "title": "L'Accessoire Mode Ultime", "description": "Plus que des écouteurs — une partie de la tenue. La finition chrome ajoute ce petit truc en plus." } },
        { "type": "card", "settings": { "title": "Bougez Différemment", "description": "Mettez-les et toute votre allure change. Ce détail final qui fait tourner les têtes." } }
      ]
    }
  ]
}
{% endschema %}
