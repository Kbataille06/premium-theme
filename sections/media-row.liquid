<section class="media-row section-padding">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="media-row__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.badge_text != blank -%}
      <div class="media-row__badge">
        {%- if section.settings.badge_icon == 'instagram' -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        {%- elsif section.settings.badge_icon == 'tiktok' -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
        {%- endif -%}
        {{ section.settings.badge_text }}
      </div>
    {%- endif -%}

    <div class="media-row__grid media-row__grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div class="media-row__item" {{ block.shopify_attributes }}>
          {%- if block.settings.video_url != blank -%}
            <div class="media-row__video-wrapper">
              <video
                class="media-row__video"
                src="{{ block.settings.video_url }}"
                autoplay
                muted
                loop
                playsinline
              ></video>
              <div class="media-row__mute-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
              </div>
            </div>
          {%- elsif block.settings.image != blank -%}
            <div class="media-row__image-wrapper">
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'media-row__image', alt: block.settings.alt_text }}
              {%- if block.settings.show_mute_icon -%}
                <div class="media-row__mute-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
                </div>
              {%- endif -%}
            </div>
          {%- else -%}
            <div class="media-row__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
          {%- if block.settings.label != blank -%}
            <p class="media-row__label">{{ block.settings.label }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Media row",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Over 42M Views On Instagram"
    },
    {
      "type": "select",
      "id": "badge_icon",
      "label": "Badge icon",
      "options": [
        { "value": "instagram", "label": "Instagram" },
        { "value": "tiktok", "label": "TikTok" },
        { "value": "none", "label": "None" }
      ],
      "default": "instagram"
    }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media item",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (.mp4)",
          "info": "Upload a video file to Shopify Files and paste the URL here."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image or GIF (used if no video URL)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "checkbox",
          "id": "show_mute_icon",
          "label": "Show mute icon overlay",
          "default": true
        },
        {
          "type": "text",
          "id": "label",
          "label": "Caption (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media row",
      "blocks": [
        { "type": "media", "settings": { "show_mute_icon": true } },
        { "type": "media", "settings": { "show_mute_icon": true } },
        { "type": "media", "settings": { "show_mute_icon": true } },
        { "type": "media", "settings": { "show_mute_icon": true } },
        { "type": "media", "settings": { "show_mute_icon": true } }
      ]
    }
  ]
}
{% endschema %}
