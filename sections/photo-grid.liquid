<section class="photo-grid section-padding">
  <div class="container">
    <div class="photo-grid__header text-center">
      <h2 class="photo-grid__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="accent-text">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="photo-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.badge_text != blank -%}
        {%- assign tk_path = 'M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z' -%}
        <div class="social-badge">
          <svg class="social-badge__icon" viewBox="0 0 24 24" width="14" height="14" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="{{ tk_path }}" fill="#25F4EE" transform="translate(-0.9,0.9)"/>
            <path d="{{ tk_path }}" fill="#FE2C55" transform="translate(0.9,-0.9)"/>
            <path d="{{ tk_path }}" fill="#111111"/>
          </svg>
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}
    </div>

    <div class="photo-grid__grid">
      {%- for block in section.blocks -%}
        <div class="photo-grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', class: 'photo-grid__img', alt: 'Customer photo' }}
          {%- else -%}
            <div class="photo-grid__img photo-grid__img--placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Photo grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved By" },
    { "type": "text", "id": "heading_accent", "label": "Accent (gray)", "default": "8,000+" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "A showcase of images" },
    { "type": "text", "id": "badge_text", "label": "TikTok badge", "default": "Over 31M Views On TikTok" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Photo grid",
      "blocks": [
        { "type": "photo" }, { "type": "photo" }, { "type": "photo" },
        { "type": "photo" }, { "type": "photo" }, { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
