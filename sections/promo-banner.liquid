<section class="promo-banner">
  <div class="promo-banner__inner container">
    <div
      class="promo-banner__card"
      {%- if section.settings.bg_image != blank -%}
        style="background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');"
      {%- else -%}
        style="background-color: {{ section.settings.bg_color }};"
      {%- endif -%}
    >
      <div class="promo-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      <div class="promo-banner__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="promo-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="promo-banner__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="promo-banner__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn--white btn--lg btn--full-mobile">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.badge_text != blank -%}
          <p class="promo-banner__badge">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {{ section.settings.badge_text }}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Last Chance!\nFinal Re-Stock of 2026"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Due to overwhelming demand and record volume, this is our final restock of the year. Once this batch is gone, it will not be returning — secure your pair before they disappear."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color (fallback)",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Dark overlay opacity",
      "default": 45
    }
  ],
  "presets": [
    {
      "name": "Promo banner"
    }
  ]
}
{% endschema %}
