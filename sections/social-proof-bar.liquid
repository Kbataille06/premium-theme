<section class="social-proof-bar" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="container">
    <div class="social-proof-bar__inner">
      {%- for block in section.blocks -%}
        <div class="social-proof-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="social-proof-bar__icon">{{ block.settings.icon }}</span>
          {%- endif -%}
          <div>
            <strong class="social-proof-bar__value">{{ block.settings.value }}</strong>
            <span class="social-proof-bar__label">{{ block.settings.label }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social proof bar",
  "max_blocks": 5,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#151515"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji/icon",
          "default": "⭐"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "150,000+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy Customers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof bar",
      "blocks": [
        { "type": "stat", "settings": { "icon": "⭐", "value": "4.9/5", "label": "Average Rating" } },
        { "type": "stat", "settings": { "icon": "👥", "value": "150,000+", "label": "Happy Customers" } },
        { "type": "stat", "settings": { "icon": "🛡️", "value": "30-Day", "label": "Money Back Guarantee" } },
        { "type": "stat", "settings": { "icon": "🚚", "value": "Free", "label": "Shipping Available" } }
      ]
    }
  ]
}
{% endschema %}
