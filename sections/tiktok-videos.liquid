<section class="tiktok-videos section-padding">
  <div class="container">
    <div class="section-header text-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.view_count != blank -%}
        <p class="tiktok-videos__view-count">
          <span class="tiktok-videos__tiktok-logo">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
          </span>
          {{ section.settings.view_count }} Views on TikTok
        </p>
      {%- endif -%}
    </div>

    <div class="tiktok-videos__grid">
      {%- for block in section.blocks -%}
        <div class="tiktok-videos__item" {{ block.shopify_attributes }}>
          {%- if block.settings.video_url != blank -%}
            <div class="tiktok-videos__embed-wrapper">
              {%- assign video_id = block.settings.video_url | split: '/' | last | split: '?' | first -%}
              <iframe
                src="https://www.tiktok.com/embed/v2/{{ video_id }}"
                class="tiktok-videos__iframe"
                allowfullscreen
                scrolling="no"
                allow="encrypted-media;"
                loading="lazy"
              ></iframe>
            </div>
          {%- elsif block.settings.thumbnail != blank -%}
            <div class="tiktok-videos__thumbnail">
              {{ block.settings.thumbnail | image_url: width: 400 | image_tag: loading: 'lazy', alt: 'TikTok video' }}
              <div class="tiktok-videos__play-btn" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            </div>
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <p class="tiktok-videos__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TikTok videos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "view_count",
      "label": "View count (e.g. 56M)",
      "default": "56M"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "TikTok video URL"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image (fallback)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TikTok videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
