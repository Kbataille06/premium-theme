{%- capture tp_star -%}<svg class="we-star" viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect width="96" height="96" fill="#484848"/><path d="M48 64.7L62.6 61l6.1 18.8zm33.6-24.3H55.9L48 16.2l-7.9 24.2H14.4l20.8 15-7.9 24.2 20.8-15 12.8-9.2z" fill="#fff"/></svg>{%- endcapture -%}

<section class="we section-padding">
  <div class="container">
    <div class="we__header text-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="we__heading">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <span class="we__accent">{{ section.settings.heading_accent }}</span>
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.show_summary -%}
        <div class="we__summary">
          <span class="we__summary-stars">{{ tp_star }}{{ tp_star }}{{ tp_star }}{{ tp_star }}{{ tp_star }}</span>
          <span class="we__summary-text"><strong>{{ section.settings.summary_label }} {{ section.settings.summary_score }}</strong> {{ section.settings.summary_count }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="we__carousel" data-reviews-carousel>
      <div class="we__track" data-reviews-track>
        {%- for block in section.blocks -%}
          {%- assign initial = block.settings.author_name | slice: 0 | upcase -%}
          <article class="we__card" {{ block.shopify_attributes }}>
            <div class="we__card-stars">
              {%- assign rating = block.settings.rating | default: 5 -%}
              {%- for i in (1..rating) -%}{{ tp_star }}{%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="we__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            <p class="we__card-text">{{ block.settings.text }}</p>
            <div class="we__author">
              <span class="we__avatar">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.author_name }}
                {%- else -%}{{ initial }}{%- endif -%}
              </span>
              <span class="we__author-name">{{ block.settings.author_name }}</span>
              {%- if block.settings.verified -%}
                <svg class="we__verified" viewBox="0 0 16 16" width="14" height="14" fill="#181b1d" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M10.067.87a2.89 2.89 0 0 0-4.134 0l-.622.638-.89-.011a2.89 2.89 0 0 0-2.924 2.924l.01.89-.636.622a2.89 2.89 0 0 0 0 4.134l.637.622-.011.89a2.89 2.89 0 0 0 2.924 2.924l.89-.01.622.636a2.89 2.89 0 0 0 4.134 0l.622-.637.89.011a2.89 2.89 0 0 0 2.924-2.924l-.01-.89.636-.622a2.89 2.89 0 0 0 0-4.134l-.637-.622.011-.89a2.89 2.89 0 0 0-2.924-2.924l-.89.01zm.287 5.984-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708.708"/></svg>
                <span class="we__verified-label">{{ section.settings.verified_label }}</span>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      <div class="we__nav">
        <button class="we__arrow we__arrow--prev" data-reviews-prev aria-label="Précédent">‹</button>
        <button class="we__arrow we__arrow--next" data-reviews-next aria-label="Suivant">›</button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Avis « what everyone »",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "ce que tout le monde" },
    { "type": "text", "id": "heading_accent", "label": "Accent (gris clair)", "default": "en dit..." },
    { "type": "checkbox", "id": "show_summary", "label": "Afficher la note globale", "default": true },
    { "type": "text", "id": "summary_label", "label": "Label note", "default": "Très bien" },
    { "type": "text", "id": "summary_score", "label": "Score", "default": "4,9/5" },
    { "type": "text", "id": "summary_count", "label": "Texte avis", "default": "sur 1046 avis vérifiés" },
    { "type": "text", "id": "verified_label", "label": "Label vérifié", "default": "Client vérifié" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis",
      "settings": [
        { "type": "range", "id": "rating", "label": "Étoiles", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "title", "label": "Titre", "default": "Ça vaut le coup !" },
        { "type": "textarea", "id": "text", "label": "Avis", "default": "On voit qu'ils ne sont pas faits à la va-vite. Le boîtier métallique est solide et le son est net. Parfaits pour les trajets." },
        { "type": "image_picker", "id": "avatar", "label": "Avatar (vide = initiale)" },
        { "type": "text", "id": "author_name", "label": "Nom", "default": "Jessey M." },
        { "type": "checkbox", "id": "verified", "label": "Client vérifié", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis « what everyone »",
      "blocks": [
        { "type": "review", "settings": { "title": "Ça vaut le coup !", "text": "On voit qu'ils ne sont pas faits à la va-vite. Le boîtier métallique est solide et le son est net sans déborder. Parfaits pour les trajets.", "author_name": "Jessey M." } },
        { "type": "review", "settings": { "title": "On me demande où je les ai eus.", "text": "Ils ressemblent plus à un accessoire qu'à des écouteurs. Super confortables et la connexion sans latence est un vrai plus.", "author_name": "Liam B." } },
        { "type": "review", "settings": { "title": "Ajustement parfait", "text": "Ils tiennent parfaitement et ne font pas mal même après des heures. Je les porte en snowboard tout le temps.", "author_name": "Jake A." } },
        { "type": "review", "settings": { "title": "Pas déçu", "text": "La finition chrome est super élégante. Le son est excellent et ils sont devenus mes écouteurs du quotidien.", "author_name": "Alex R." } }
      ]
    }
  ]
}
{% endschema %}
